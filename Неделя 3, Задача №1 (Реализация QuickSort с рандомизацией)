import random
def partition(arr, low, high):
    """
    Процедура разделения (partition) по схеме Lomuto.
    В качестве pivot используется элемент arr[high].
    Функция переставляет элементы так, что:
    - все элементы <= pivot находятся слева
    - все элементы > pivot находятся справа
    Возвращает индекс pivot после разделения.
    """
    pivot = arr[high]  # опорный элемент (pivot)
    i = low - 1        # индекс меньшего элемента
    # Проходим по массиву от low до high-1
    for j in range(low, high):
        # Если текущий элемент меньше или равен pivot
        if arr[j] <= pivot:
            i += 1
            # Меняем местами arr[i] и arr[j]
            arr[i], arr[j] = arr[j], arr[i]
    # После прохода ставим pivot на правильную позицию
    arr[i + 1], arr[high] = arr[high], arr[i + 1]
    # Возвращаем индекс pivot
    return i + 1
def quick_sort(arr, low, high):
    """
    Быстрая сортировка (QuickSort) с рандомизированным выбором pivot.
    Сортирует массив arr на месте (in-place).
    """
    if low < high:
        # Выбираем случайный индекс в диапазоне [low, high]
        random_index = random.randint(low, high)
        # Меняем случайный элемент с последним,
        # чтобы использовать его как pivot в схеме Lomuto
        arr[random_index], arr[high] = arr[high], arr[random_index]
        # Выполняем разделение
        pivot_index = partition(arr, low, high)
        # Рекурсивно сортируем левую часть
        quick_sort(arr, low, pivot_index - 1)
        # Рекурсивно сортируем правую часть
        quick_sort(arr, pivot_index + 1, high)
